# 로컬 개발/테스트는 이 파일을 복사해 .env.development / .env.test 로 만든다(둘 다 gitignore).
# infra: `mise run infra up --env development` 이 apps/server/.env.<env> 를 읽는다.

NODE_ENV=development
PORT=3007

# Postgres (docker compose). 다른 로컬 프로젝트(5432~5434)와 겹치지 않게 5435 사용.
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_USER=developer
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pokedex_dev

# 내부 로그인 JWT 서명 키(운영은 반드시 강한 난수로 교체)
JWT_SECRET=change-me
JWT_EXPIRES_IN=30m

# Claude API 키. console.anthropic.com에서 발급. 추천·파티 이미지 OCR에 필요.
ANTHROPIC_API_KEY=sk-ant-api03-...

# (선택) 모델 변경. 기본 OCR claude-opus-4-7, 추천 claude-sonnet-4-6.
# ANTHROPIC_MODEL=claude-opus-4-7
