{
  "name": "@pokedex-agent/pokedex-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/paths.d.ts",
      "default": "./dist/paths.js"
    },
    "./fallback": {
      "types": "./dist/gen9-fallback.d.ts",
      "default": "./dist/gen9-fallback.js"
    },
    "./data/*": "./data/*.json"
  },
  "files": ["dist", "data"],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.0",
    "vitest": "^4.1.5"
  }
}
